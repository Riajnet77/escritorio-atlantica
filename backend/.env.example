# Copie este arquivo para .env e preencha os valores

# MongoDB Atlas - Cole a string de conexão do MongoDB Atlas aqui
MONGODB_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=escritorio_atlantica

# Segurança
SECRET_KEY=sua-chave-secreta-aqui-troque-isso

# Email (opcional - para notificações de contato)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app
EMAIL_TO=contato@escritorioatlantica.com.br
